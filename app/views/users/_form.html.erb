<%= form_with model: user, class: "space-y-4" do |f| %>
  <% if user.errors.any? %>
    <div class="bg-red-50 border border-red-300 rounded p-4">
      <p class="text-red-700 font-semibold text-xs sm:text-sm mb-2">入力内容にエラーがあります。</p>

      <ul class="list-disc list-inside text-red-600 text-xs sm:text-sm space-y-1">
        <% user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">
    <div>
      <%= f.label :name, "従業員名", class: "block text-xs sm:text-sm text-gray-700 mb-1" %>

      <%= f.text_field :name,
                       class: "w-full border border-gray-300 rounded px-3 py-2 h-8 sm:h-9 text-xs sm:text-sm" %>
    </div>

    <div>
      <%= f.label :email_address, "メールアドレス", class: "block text-xs sm:text-sm text-gray-700 mb-1" %>

      <%= f.email_field :email_address,
                        class: "w-full border border-gray-300 rounded px-3 py-2 h-8 sm:h-9 text-xs sm:text-sm" %>
    </div>
  </div>

  <div>
    <%= f.label :password,
        user.persisted? ? "パスワード（変更する場合のみ）" : "パスワード",
        class: "block text-xs sm:text-sm text-gray-700 mb-1" %>

    <%= f.password_field :password,
                         class: "w-full border border-gray-300 rounded px-3 py-2 h-8 sm:h-9 text-xs sm:text-sm" %>
  </div>

  <% if Current.user.admin? %>
    <div class="flex items-center gap-2">
      <%= f.check_box :admin, class: "rounded" %>
      <%= f.label :admin, "管理者権限を付与", class: "text-xs sm:text-sm text-gray-700" %>
    </div>
  <% end %>

  <div class="flex justify-end pt-2">
    <%= f.submit user.new_record? ? "登録" : "更新",
                 class: "px-4 h-8 sm:h-9 bg-blue-500 text-white rounded hover:bg-blue-600 text-xs sm:text-sm inline-flex items-center justify-center whitespace-nowrap cursor-pointer" %>
  </div>
<% end %>
