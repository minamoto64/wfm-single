<%= form_with(model: Comment.new, url: comments_path, local: true, class: "space-y-3") do |f| %>

  <%= hidden_field_tag :commentable_type, commentable.class.name %>
  <%= hidden_field_tag :commentable_id, commentable.id %>

  <%= f.text_area :content,
                  rows: 2,
                  placeholder: "コメントを入力してください...",
                  class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
                  required: true %>

  <%= f.submit "コメントを投稿",
                class: "px-4 py-2 bg-blue-500 text-white rounded text-sm hover:bg-blue-600 cursor-pointer" %>
<% end %>
