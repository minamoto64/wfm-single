<div class="border-t-4 border-gray-300 pt-6">
  <h2 class="text-base sm:text-lg font-semibold mb-3">コメント</h2>
  <div class="space-y-2 mb-4">
    <% if commentable.comments.any? %>
      <%= render commentable.comments %>
    <% else %>
      <div class="bg-gray-50 p-3 rounded text-xs sm:text-sm text-gray-500">
        まだコメントはありません。
      </div>
    <% end %>
  </div>
  <%= render 'comments/form', commentable: commentable %>
</div>
