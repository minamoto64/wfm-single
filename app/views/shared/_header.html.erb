<header class="bg-white shadow fixed top-0 inset-x-0 z-20">
  <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
    <h1 class="text-xl font-bold">
      <%= link_to "店舗業務管理システム", root_path, class: "hover:text-blue-600" %>
    </h1>

    <%= render "shared/user_menu" %>
  </div>

  <nav class="bg-white border-b-2 border-gray-300"
        data-controller="tabs"
        data-tabs-current-value="<%= controller_name %>"
        aria-label="メインナビゲーション">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex gap-1" role="tablist">
        <% navigation_tabs.each do |tab| %>
          <%= tab_link_to(tab) %>
        <% end %>
      </div>
    </div>
  </nav>
</header>
