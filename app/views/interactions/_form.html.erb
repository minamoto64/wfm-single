<%= form_with model: interaction, class: "space-y-4" do |f| %>
  <% if interaction.errors.any? %>
    <div class="bg-red-50 border border-red-300 rounded p-4">
      <p class="text-red-700 font-semibold text-sm mb-2">入力内容にエラーがあります。</p>

      <ul class="list-disc list-inside text-red-600 text-sm space-y-1">
        <% interaction.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.hidden_field :parent_id if interaction.parent_id.present? %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">
    <div>
      <%= f.label :customer_id, "顧客", class: "block text-sm text-gray-700 mb-1" %>

      <% if interaction.new_record? && @parent_interaction.nil? %>
        <%= f.collection_select :customer_id,
                                Customer.order(:name),
                                :id,
                                :name,
                                { prompt: "選択してください" },
                                { class: "w-full border border-gray-300 rounded px-3 py-2 h-8 sm:h-9 text-xs sm:text-sm" } %>
      <% else %>
        <%= f.hidden_field :customer_id %>

        <div class="w-full border border-gray-200 rounded px-3 py-2 h-8 sm:h-9 text-xs sm:text-sm bg-gray-100 text-gray-600 flex items-center">
          <%= interaction.customer.name %>
        </div>
      <% end %>
    </div>

    <div>
      <%= f.label :channel, "問合せ種別", class: "block text-sm text-gray-700 mb-1" %>

      <%= f.select :channel,
                   [["電話", "phone"], ["店頭", "in_person"], ["メール", "email"], ["WEB", "web"], ["SNS", "sns"]],
                   { prompt: "選択してください" },
                   { class: "w-full border border-gray-300 rounded px-3 py-2 h-8 sm:h-9 text-xs sm:text-sm" } %>
    </div>

    <div>
      <%= f.label :occurred_at, "応対日時", class: "block text-sm text-gray-700 mb-1" %>

      <%= f.datetime_local_field :occurred_at,
                                 class: "w-full border border-gray-300 rounded px-3 py-2 h-8 sm:h-9 text-xs sm:text-sm xl:text-sm" %>
    </div>

    <div>
      <span class="block text-sm text-gray-700 mb-1">対応状況</span>

      <label class="flex items-center h-8 sm:h-9">
        <%= f.check_box :completed, class: "rounded" %>
        <span class="ml-2 text-xs sm:text-sm text-gray-700">対応完了</span>
      </label>
    </div>
  </div>

  <div>
    <%= f.label :request_content, "要望内容", class: "block text-sm text-gray-700 mb-1" %>

    <%= f.text_area :request_content,
                    rows: 4,
                    class: "w-full border border-gray-300 rounded px-3 py-2 text-xs sm:text-sm" %>
  </div>

  <div>
    <%= f.label :response_result, "対応結果", class: "block text-sm text-gray-700 mb-1" %>

    <%= f.text_area :response_result,
                    rows: 4,
                    class: "w-full border border-gray-300 rounded px-3 py-2 text-xs sm:text-sm" %>
  </div>

  <div>
    <%= f.label :images, "画像", class: "block text-sm text-gray-700 mb-1" %>

    <div class="w-full border border-gray-300 rounded px-3 py-2 text-xs sm:text-sm bg-white">
      <%= f.file_field :images,
                       multiple: true,
                       accept: "image/jpeg,image/png,image/gif",
                       class: "w-full text-xs sm:text-sm text-gray-600
                               file:mr-3 file:py-1 file:px-3
                               file:rounded file:border file:border-gray-300
                               file:text-sm file:text-gray-600 file:bg-gray-50
                               hover:file:bg-gray-100 file:cursor-pointer cursor-pointer" %>
    </div>

    <p class="mt-1 text-xs text-gray-400">
      JPEG / PNG / GIF・最大 10MB・複数可
    </p>
  </div>

  <div class="flex justify-end pt-2">
    <%= f.submit interaction.new_record? ? "登録" : "更新",
                 class: "px-4 h-8 sm:h-9 bg-blue-500 text-white rounded hover:bg-blue-600 text-xs sm:text-sm inline-flex items-center justify-center whitespace-nowrap" %>
  </div>
<% end %>
