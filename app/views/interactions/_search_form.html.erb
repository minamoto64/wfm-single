<div class="flex items-center justify-between w-full">
  <h2 class="text-sm font-semibold">検索</h2>

  <svg data-disclosure-target="icon"
       class="w-4 h-4 text-gray-500 transition-transform duration-200"
       fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
  </svg>
</div>

<div data-disclosure-target="panel"
     data-action="click->disclosure#stop"
     class="hidden mt-3">
  <%= search_form_for q, url: interactions_path, method: :get,
                      html: { class: "text-sm w-full", data: { turbo_frame: "interactions_list" } } do |f| %>
    <div class="grid grid-cols-2 md:grid-cols-4 xl:flex xl:flex-nowrap xl:items-end gap-2 xl:gap-3 w-full">

      <div class="w-full xl:w-28 shrink-0 order-1">
        <%= f.label :occurred_at_gteq, "応対日（いつから）", class: "block text-xs text-gray-500 mb-1" %>
        <%= f.date_field :occurred_at_gteq,
                         class: "w-full border border-gray-300 rounded px-2 h-8 sm:h-9 text-xs sm:text-sm text-gray-600" %>
      </div>

      <div class="w-full xl:w-28 shrink-0 order-2">
        <%= f.label :occurred_at_lteq, "応対日（いつまで）", class: "block text-xs text-gray-500 mb-1" %>
        <%= f.date_field :occurred_at_lteq,
                         class: "w-full border border-gray-300 rounded px-2 h-8 sm:h-9 text-xs sm:text-sm text-gray-600" %>
      </div>

      <div class="w-full xl:w-44 shrink-0 order-3">
        <%= f.label :customer_name_cont, "顧客名", class: "block text-xs text-gray-500 mb-1" %>
        <%= f.search_field :customer_name_cont,
                           class: "w-full border border-gray-300 rounded px-3 h-8 sm:h-9 text-xs sm:text-sm text-gray-600",
                           placeholder: "例）鈴木" %>
      </div>

      <div class="w-full xl:w-28 shrink-0 order-4">
        <%= f.label :channel_eq, "問合せ種別", class: "block text-xs text-gray-500 mb-1" %>
        <%= f.select :channel_eq,
                     [["指定なし", ""], ["電話", "phone"], ["店頭", "in_person"], ["メール", "email"], ["WEB", "web"], ["SNS", "sns"]],
                     {},
                     class: "w-full border border-gray-300 rounded px-2 h-8 sm:h-9 text-xs sm:text-sm text-gray-600" %>
      </div>

      <div class="w-full xl:w-44 shrink-0 order-5">
        <%= f.label :customer_phone_cont, "電話番号", class: "block text-xs text-gray-500 mb-1" %>
        <%= f.search_field :customer_phone_cont,
                           class: "w-full border border-gray-300 rounded px-3 h-8 sm:h-9 text-xs sm:text-sm text-gray-600",
                           placeholder: "部分一致可" %>
      </div>

      <div class="w-full xl:w-40 shrink-0 order-6">
        <%= f.label :user_name_cont, "担当者名", class: "block text-xs text-gray-500 mb-1" %>
        <%= f.search_field :user_name_cont,
                           class: "w-full border border-gray-300 rounded px-3 h-8 sm:h-9 text-xs sm:text-sm text-gray-600",
                           placeholder: "例）佐藤" %>
      </div>

      <div class="w-full xl:w-28 shrink-0 order-7">
        <%= f.label :completed_eq, "対応状況", class: "block text-xs text-gray-500 mb-1" %>
        <%= f.select :completed_eq,
                     [["指定なし", ""], ["対応中", false], ["対応完了", true]],
                     {},
                     class: "w-full border border-gray-300 rounded px-2 h-8 sm:h-9 text-xs sm:text-sm text-gray-600" %>
      </div>

      <div class="flex items-end justify-end justify-self-end gap-2 w-full order-8 md:col-start-4 xl:w-auto xl:ml-auto xl:mt-0 shrink-0 pt-1 xl:pt-0">
        <%= link_to "クリア",
                    interactions_path,
                    class: "w-auto px-3 h-8 sm:h-9 border border-gray-300 rounded text-gray-500 text-xs sm:text-sm inline-flex items-center justify-center whitespace-nowrap bg-white hover:bg-gray-50" %>

        <%= f.submit "検索",
                     class: "w-auto px-4 h-8 sm:h-9 bg-blue-500 text-white rounded hover:bg-blue-600 text-xs sm:text-sm inline-flex items-center justify-center whitespace-nowrap cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>
