<div class="max-w-4xl mx-auto px-4 py-4">
  <div class="mb-4">
    <% if @interaction.parent %>
      <%= link_to "← 元の応対履歴に戻る",
                  interaction_path(@parent_interaction),
                  class: "text-blue-600 hover:underline text-xs sm:text-sm" %>
    <% else %>
      <%= link_to "← 一覧に戻る",
                  interactions_path,
                  class: "text-blue-600 hover:underline text-xs sm:text-sm" %>
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow-lg p-6">
    <div class="border-b-4 border-blue-500 pb-4 mb-6">
      <h1 class="text-lg sm:text-xl font-bold">
        <%= @parent_interaction ? "関連応対履歴の登録" : "応対履歴の新規登録" %>
      </h1>
    </div>

    <%= render "form", interaction: @interaction %>
  </div>
</div>

